# =========================
# Discord Secrets
# =========================
TOKEN=                       # للمشروع الحالي
DISCORD_TOKEN=               # للمشروع الجديد (discord-bot)

# =========================
# Runtime
# =========================
BOT_LOG_LEVEL=INFO
BOT_PREFIX=!
BOT_STATUS=🌍 النيكسس ينتظرك | /ابدأ

# =========================
# Command Sync
# =========================
# للتطوير السريع: ضع Guild ID
BOT_GUILD_ID=
# للإنتاج: true لمزامنة Global
SYNC_GLOBAL_COMMANDS=true

# =========================
# Policy / Content
# =========================
CHANNEL_POLICY_MODE=strict   # strict | soft | off
NEXUS_CONTENT_DIR=./content

# =========================
# Startup / Safety
# =========================
BOT_STARTUP_TIMEOUT_SEC=40
